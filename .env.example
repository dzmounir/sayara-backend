# ─── WhatsApp Business API (Meta) ─────────────────────────────────────────────
# Token de vérification webhook (choisi par vous — doit correspondre dans Meta)
WHATSAPP_VERIFY_TOKEN=sayara_webhook_secret_2024

# Token d'accès permanent (System User token dans Meta Business Suite)
WHATSAPP_ACCESS_TOKEN=EAAxxxxxx...

# ID du numéro de téléphone WhatsApp Business (dans Meta > WhatsApp > Numéros)
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# ─── Serveur ───────────────────────────────────────────────────────────────────
PORT=3001

# URL publique de ce serveur (Railway auto-assign ou domaine custom)
SERVER_HOST=sayara-backend.up.railway.app

# ─── Make.com ──────────────────────────────────────────────────────────────────
# URL du webhook Make.com — scénario Accueil (copier depuis Make > Webhooks)
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/xxxxxxxxxxxxxxxx

# URL du webhook Make.com — scénario CNI Vérification (15)
MAKE_CNI_WEBHOOK_URL=https://hook.eu2.make.com/xxxxxxxxxxxxxxxx

# URL du webhook Make.com — confirmation manuelle CNI par courtier (dashboard)
MAKE_CNI_CONFIRM_WEBHOOK=https://hook.eu2.make.com/xxxxxxxxxxxxxxxx

# ─── Airtable ──────────────────────────────────────────────────────────────────
# ID de la base principale (commence par app...)
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Clé API personnelle (Airtable > Account > API > Personal access token)
# Scopes requis : data.records:read, data.records:write
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Anthropic (Claude) ────────────────────────────────────────────────────────
# Clé API Anthropic (console.anthropic.com > API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Carbone.io ────────────────────────────────────────────────────────────────
# Clé API Carbone (app.carbone.io > Settings > API)
CARBONE_API_KEY=eyJhbGci...

# IDs des templates uploadés sur Carbone.io Studio
CARBONE_TEMPLATE_CONTRAT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CARBONE_TEMPLATE_RECONNAISSANCE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Drive ──────────────────────────────────────────────────────────────
# ID du dossier racine Sayara sur Drive (dans l'URL du dossier)
GDRIVE_FOLDER_ROOT=1BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxX

# Sous-dossiers (créer manuellement ou via script)
GDRIVE_FOLDER_DEVIS=1CxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxX
GDRIVE_FOLDER_CONTRATS=1DxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxX
GDRIVE_FOLDER_DOSSIERS=1ExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxX

# ─── WhatsApp numéros internes ─────────────────────────────────────────────────
# Numéro WhatsApp du courtier principal (format international sans +)
COURTIER_WHATSAPP=33760469653
COURTIER_WHATSAPP_NUMBER=33760469653

# Numéro WhatsApp du notaire partenaire (reçoit les confirmations de RDV)
NOTAIRE_WHATSAPP_NUMBER=

# ─── WhatsApp dédié sourceurs ───────────────────────────────────────────────────
# ID du numéro WhatsApp Business dédié aux sourceurs (Meta > WhatsApp > Numéros)
WHATSAPP_SOURCEUR_PHONE_NUMBER_ID=

# Liste blanche de numéros sourceurs connus (format international, séparés par virgule)
SOURCEUR_WHITELIST=

# ─── Airtable — tables supplémentaires ─────────────────────────────────────────
# Table PRIX_SOURCEURS (ID commençant par tbl...)
AIRTABLE_PRIX_SOURCEURS_TABLE=tblkosDM1HA6SbW0V

# Table SOURCEURS
AIRTABLE_SOURCEURS_TABLE=tblGeoLTGnBKhlAsK

# Table CATALOGUE_COMPARATIF (à créer dans Airtable, puis renseigner l'ID)
AIRTABLE_CATALOGUE_COMPARATIF_TABLE=

# Table IMPORT_HISTORY (à créer dans Airtable, puis renseigner l'ID)
AIRTABLE_IMPORT_HISTORY_TABLE=

# ─── Catalogue sourceurs ───────────────────────────────────────────────────────
# URL publique du fichier template Excel envoyé aux sourceurs
CATALOGUE_TEMPLATE_URL=

# Clé API Google Sheets (pour lecture des Google Sheets partagés)
GOOGLE_SHEETS_API_KEY=

# ─── Make.com webhooks supplémentaires ─────────────────────────────────────────
